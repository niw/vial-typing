{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!data"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "html": {
    "formatter": {
      "enabled": true
    }
  },
  "linter": {
    "rules": {
      "complexity": {
        "useSimpleNumberKeys": "off",
        "noImportantStyles": "off"
      },
      "style": {
        "useTemplate": "off",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off"
      }
    }
  }
}
