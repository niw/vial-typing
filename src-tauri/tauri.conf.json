{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vial Typing",
  "version": "0.1.0",
  "identifier": "at.niw.vial-typing",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --port 1420 --strictPort",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Vial Typing",
        "width": 1200,
        "height": 900,
        "minWidth": 720,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns"],
    "category": "Education"
  }
}
